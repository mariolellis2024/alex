generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id               String   @id @default(cuid())
  publicDomain     String?
  evolutionUrl     String?
  evolutionApiKey  String?
  setupCompleted   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Proxy {
  id        String   @id @default(cuid())
  host      String
  port      Int
  protocol  String   @default("http")
  username  String?
  password  String?
  status    String   @default("ACTIVE")
  lastCheck DateTime?
  
  connections Connection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Connection {
  id             String   @id @default(cuid())
  instanceName   String   @unique
  internalName   String
  number         String?
  status         String   @default("DISCONNECTED")
  dailyLimit     Int      @default(50)
  warmupState    Int      @default(0)
  
  proxyId        String?
  proxy          Proxy?   @relation(fields: [proxyId], references: [id])
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Pixel {
  id              String   @id @default(cuid())
  name            String
  pixelId         String   @unique
  capiToken       String
  testEventCode   String?
  trackingLinks   TrackingLink[]
  capiEvents      CapiEvent[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TrackingLink {
  id                 String   @id @default(cuid())
  code               String   @unique
  destinationNumber  String?
  initialMessage     String
  pixelId            String?
  pixel              Pixel?   @relation(fields: [pixelId], references: [id])
  funnelId           String?
  funnel             Funnel?  @relation(fields: [funnelId], references: [id])
  clicks             Click[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Click {
  id               String   @id @default(cuid())
  trackingLinkId   String
  trackingLink     TrackingLink @relation(fields: [trackingLinkId], references: [id])
  fbclid           String?
  fbp              String?
  fbc              String?
  ip               String?
  userAgent        String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  matchedLeadId    String?
  lead             Lead?    @relation(fields: [matchedLeadId], references: [id])
  createdAt        DateTime @default(now())
}

model Lead {
  id             String      @id @default(cuid())
  phone          String      @unique
  name           String?
  email          String?
  isCustomer     Boolean     @default(false)
  tags           String[]
  clicks         Click[]
  orders         Order[]
  funnelRuns     FunnelRun[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Order {
  id               String   @id @default(cuid())
  kiwifyOrderId    String   @unique
  leadId           String?
  lead             Lead?    @relation(fields: [leadId], references: [id])
  productName      String
  amount           Int      // em centavos
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model KiwifyWebhook {
  id             String   @id @default(cuid())
  eventId        String?
  event          String
  payload        Json
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model CapiEvent {
  id             String   @id @default(cuid())
  pixelId        String
  pixel          Pixel    @relation(fields: [pixelId], references: [id])
  eventName      String
  eventId        String
  payload        Json
  response       Json?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model Funnel {
  id              String          @id @default(cuid())
  name            String
  description     String?
  versions        FunnelVersion[]
  trackingLinks   TrackingLink[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model FunnelVersion {
  id              String          @id @default(cuid())
  funnelId        String
  funnel          Funnel          @relation(fields: [funnelId], references: [id])
  version         Int             @default(1)
  nodes           Json            @default("[]")
  edges           Json            @default("[]")
  isActive        Boolean         @default(false)
  runs            FunnelRun[]
  createdAt       DateTime        @default(now())
}

model FunnelRun {
  id               String          @id @default(cuid())
  funnelVersionId  String
  funnelVersion    FunnelVersion   @relation(fields: [funnelVersionId], references: [id])
  leadId           String
  lead             Lead            @relation(fields: [leadId], references: [id])
  status           String          @default("RUNNING")
  currentNodeId    String?
  state            Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}
